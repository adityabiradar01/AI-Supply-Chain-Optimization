import numpy as np
from sklearn_extra.cluster import KMedoids
from .haversine import pairwise_haversine_km

def kmedoids_geo(coords_latlon: np.ndarray, k: int, random_state: int = 42):
    """
    coords_latlon: np.array shape (n,2) [lat, lon]
    returns: medoid coords array shape (k,2)
    """
    if len(coords_latlon) < k:
        raise ValueError("k cannot be greater than number of points")

    D = pairwise_haversine_km(coords_latlon)  # km distance matrix
    model = KMedoids(n_clusters=k, metric="precomputed", init="k-medoids++", random_state=random_state)
    labels = model.fit_predict(D)
    medoids = coords_latlon[model.medoid_indices_]
    return medoids, labels
